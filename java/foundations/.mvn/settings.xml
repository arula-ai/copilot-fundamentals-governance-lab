<?xml version="1.0" encoding="UTF-8"?>
<settings xmlns="http://maven.apache.org/SETTINGS/1.2.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.2.0 https://maven.apache.org/xsd/settings-1.2.0.xsd">

  <!--
    ============================================================
    FIDELITY INTERNAL ARTIFACTORY CONFIGURATION
    ============================================================
    Base URL confirmed: https://artifactory.fmr.com/artifactory

    NOTE: libs-release-local and libs-snapshot-local are for PUBLISHING.
    The URL below (libs-release) is the DOWNLOAD/proxy mirror for Maven Central.
    If this URL doesn't work, ask Fidelity IT for their virtual repository URL.
    ============================================================
  -->

  <mirrors>
    <mirror>
      <id>fidelity-artifactory</id>
      <name>Fidelity Internal Artifactory</name>
      <mirrorOf>*</mirrorOf>
      <url>https://artifactory.fmr.com/artifactory/libs-release</url>
    </mirror>
  </mirrors>


</settings>
